# Supabase project URL (Supabase dashboard → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (Supabase dashboard → Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your deployed URL — no trailing slash (e.g. https://care.vercel.app)
# For local dev: http://localhost:3000
# Also add {NEXT_PUBLIC_SITE_URL}/auth/callback to:
#   Supabase dashboard → Authentication → URL Configuration → Redirect URLs
NEXT_PUBLIC_SITE_URL=

# Your email address — required to access /admin
# Set only in Vercel dashboard environment variables. Never commit to git.
FOUNDER_EMAIL=
